// OpenCode command snippet generated from v28.3 plus v28.4 persistent planning commands.
{
  "$schema": "https://opencode.ai/config.json",
  "command": {
    "bugfix": {
      "description": "Run an orchestrated bugfix workflow.",
      "agent": "code-workflow-orchestrator",
      "subtask": true,
      "template": "Run the bugfix workflow for: $ARGUMENTS\n\nNormalize intent first. If this is investigation-only, do not edit code. If fixing is requested, orchestrate exploration, reproduction, fix, verification, fix-level review, and code review according to normalized intent. Do not commit, push, or open PRs unless that publication is allowed by the gated-action rule. Return one consolidated markdown report."
    },
    "pr-followup": {
      "description": "Handle follow-up work for an existing PR on the same PR branch.",
      "agent": "code-workflow-orchestrator",
      "subtask": true,
      "template": "Run the existing-PR follow-up workflow for: $ARGUMENTS\n\nUse the same PR branch by default. Creating a separate PR is a gated action; proceed only when separate-PR creation is the clear normalized deliverable and the gated-action rule allows it. Commit or push only when the gated-action rule allows the exact publication action. Return one consolidated markdown report."
    },
    "issue-from-bug": {
      "description": "Verify a described bug and draft/open a factual issue.",
      "agent": "code-workflow-orchestrator",
      "subtask": true,
      "template": "Run the issue-from-bug workflow for: $ARGUMENTS\n\nVerify facts, search existing issues when issue access exists, do not invent root cause, and draft/open the issue only when the normalized action level includes issue drafting/opening. Do not fix code unless the normalized deliverable is changed code/config/UI."
    },
    "release-prep": {
      "description": "Prepare or verify release notes from actual repository history.",
      "agent": "code-workflow-orchestrator",
      "subtask": true,
      "template": "Run the release-prep workflow for: $ARGUMENTS\n\nUse only actual commits, PRs, linked issues, and final diffs. Creating tags or releases is a gated action."
    },
    "project-audit": {
      "description": "Run a broad read-only project audit.",
      "agent": "project-auditor",
      "subtask": true,
      "template": "Run a full project audit for: $ARGUMENTS\n\nDo not edit files, apply patches, commit, push, open PRs, or open issues. Orchestrate specialist subagents for audit areas that need an independent pass and return one consolidated markdown report with green/yellow/red stage status."
    },
    "create-plan": {
      "description": "Create persistent plan artifacts in plans/<plan>/.",
      "agent": "plan",
      "subtask": true,
      "template": "Create a persistent plan for: $ARGUMENTS\n\nUse docs/PERSISTENT_PLANNING_POLICY.md. Create plans/<plan>/plan.md, phase docs, and todo.md. Do not edit source code. Return a compact digest."
    },
    "resume-plan": {
      "description": "Resume an existing persistent plan from canonical artifacts.",
      "agent": "plan",
      "subtask": true,
      "template": "Resume this persistent plan: $ARGUMENTS\n\nRead plan.md, todo.md, active phase, implementation plan, reviews, latest handover, and project rules. Report current state and next safe action."
    },
    "update-plan": {
      "description": "Update plan status, todo, changelog, and next action.",
      "agent": "plan",
      "subtask": true,
      "template": "Update the persistent plan for: $ARGUMENTS\n\nUpdate todo/status/changelog/phase state in canonical plans/<plan>/ artifacts. Do not create arbitrary reports."
    },
    "generate-handover": {
      "description": "Generate a session handover for plan continuity.",
      "agent": "plan",
      "subtask": true,
      "template": "Generate a handover for: $ARGUMENTS\n\nWrite the handover into plans/<plan>/handovers/ or docs/handovers/ as appropriate. Return compact digest and path."
    },
    "author-and-verify-implementation-plan": {
      "description": "Author and verify grounded implementation plans for plan phases.",
      "agent": "plan",
      "subtask": true,
      "template": "Author and verify implementation plan(s) for: $ARGUMENTS\n\nRead plan/phase/todo and actual code. Write plans/<plan>/implementation/phase-N-impl.md. Verify referenced paths/symbols."
    },
    "review-plan": {
      "description": "Review persistent plan scope, DoD, risks, and phase boundaries.",
      "agent": "reviewer",
      "subtask": true,
      "template": "Review this persistent plan: $ARGUMENTS\n\nCheck scope, requirements, DoD, phases, risks, testing strategy. Do not edit source code."
    },
    "review-implementation-plan": {
      "description": "Review a phase implementation plan for feasibility and grounding.",
      "agent": "reviewer",
      "subtask": true,
      "template": "Review this implementation plan: $ARGUMENTS\n\nCheck grounding, feasibility, scope, tests, risks, behavioral contract, right-level fix, and gated actions."
    },
    "execute-work-package": {
      "description": "Execute an approved work package using Blueprint -> Gate -> Execute -> Digest.",
      "agent": "code-workflow-orchestrator",
      "subtask": true,
      "template": "Execute this persistent-plan work package: $ARGUMENTS\n\nUse Blueprint -> Gate -> Execute -> Digest. Do not perform git/publication actions unless the root gated-action rule allows the exact action."
    },
    "review-implementation": {
      "description": "Review completed implementation against plan acceptance criteria.",
      "agent": "reviewer",
      "subtask": true,
      "template": "Review the completed implementation for: $ARGUMENTS\n\nRead plan, phase, implementation plan, todo, and current diff. Review correctness, tests, security, behavioral contract, and acceptance criteria."
    },
    "verify": {
      "description": "Run relevant tests/checks without editing files.",
      "agent": "tester",
      "subtask": true,
      "template": "Verify the current state for: $ARGUMENTS\n\nDiscover relevant checks from project docs/configs, run the smallest checks that directly verify the requested scope first, and report exact commands/results."
    },
    "debug": {
      "description": "Investigate and fix a failing test, traceback, build failure, runtime error, or reproducible bug.",
      "agent": "debugger",
      "subtask": true,
      "template": "Debug this failure: $ARGUMENTS\n\nStart from evidence, reproduce when the provided evidence or project commands allow a non-destructive reproduction, find root cause, apply the smallest right-level fix if fixing is requested, and verify with the focused failing check."
    },
    "pr-provenance-check": {
      "description": "Verify branch provenance before commit, push, PR creation, or PR update.",
      "agent": "code-workflow-orchestrator",
      "subtask": true,
      "template": "Verify branch provenance for: $ARGUMENTS\n\nRun the read-only branch provenance gate from AGENTS.md. Fetch the base, list the full base-to-head commit range and changed files, and report whether commit/push/PR is safe. Do not edit, commit, push, rebase, reset, or force-push unless separately approved."
    },
    "pr-review": {
      "description": "Review current diff/PR for bugs, regressions, security, missing tests, and wrong fix level.",
      "agent": "reviewer",
      "subtask": true,
      "template": "Review this PR/diff/change: $ARGUMENTS\n\nStart with the startup checkpoint and gated/privacy check. Prefer OCR/open-code-review when installed and approved. If no target is specified, review the current git diff/workspace according to OCR/default reviewer behavior. Do not edit files or apply fixes. Include right-level, behavioral-contract, and test/verification findings."
    },
    "fix-level": {
      "description": "Check whether a fix is at the correct abstraction level.",
      "agent": "fix-level-reviewer",
      "subtask": true,
      "template": "Review only the fix level for: $ARGUMENTS\n\nCheck duplicated local patches, missed shared abstractions, unsafe primitive coverage, and similar call sites. Do not edit files."
    },
    "explore-code": {
      "description": "Explore codebase facts, files, call paths, and existing patterns.",
      "agent": "explore",
      "subtask": true,
      "template": "Explore the codebase for: $ARGUMENTS\n\nReturn facts, file paths, call paths, and existing patterns. Do not edit files."
    },
    "devops-check": {
      "description": "Inspect Docker/systemd/CI/deploy/runtime configuration.",
      "agent": "devops",
      "subtask": true,
      "template": "Inspect DevOps/runtime configuration for: $ARGUMENTS\n\nStart read-only. Changing services, permissions, deployment state, or production config is a gated action."
    },
    "ui-options": {
      "description": "Propose UI/web redesign options without editing code.",
      "agent": "ui-web-orchestrator",
      "subtask": true,
      "template": "Propose UI/web redesign options for: $ARGUMENTS\n\nTreat this as options-only. Read the detailed UI policy file defined in AGENTS.md when it exists. If current UI context is required, audit it first; then produce 2-3 options and stop. Do not edit code or call @frontend-ui-implementer."
    },
    "ui-audit": {
      "description": "Audit a UI/web screen for hierarchy, density, layout, and action placement.",
      "agent": "ui-ux-auditor",
      "subtask": true,
      "template": "Audit this UI/web screen or area: $ARGUMENTS\n\nRead the detailed UI policy file defined in AGENTS.md when it exists. Focus on primary user job, element priority, layout density, wasted space, primary action placement, secondary/advanced controls, settings/form ergonomics, and relevant files/styles. Do not edit files."
    },
    "ui-plan": {
      "description": "Create a concrete UI/web redesign or theme plan.",
      "agent": "ui-redesign-planner",
      "subtask": true,
      "template": "Create a concrete UI/web redesign plan for: $ARGUMENTS\n\nRead the detailed UI policy file defined in AGENTS.md when it exists. Use current project structure and components. Before using UUPM/UI UX Pro Max, perform the UUPM availability check from that policy file. If unavailable or not checked, continue without it and say so. Do not edit files. Include element priority, layout plan, component strategy, tokens if relevant, responsive behavior, accessibility notes, and implementation steps."
    },
    "ui-implement": {
      "description": "Implement an already planned UI/web redesign.",
      "agent": "frontend-ui-implementer",
      "subtask": true,
      "template": "Implement the planned UI/web redesign for: $ARGUMENTS\n\nRead the detailed UI policy file defined in AGENTS.md when it exists. Before editing, read project rules and inspect existing components/styles. Reuse current architecture. Keep the diff focused. New dependencies and new design systems are gated actions."
    },
    "ui-check": {
      "description": "Check UI/web changes for accessibility and interaction issues.",
      "agent": "accessibility-reviewer",
      "subtask": true,
      "template": "Check the UI/web changes for: $ARGUMENTS\n\nRead the detailed UI policy file defined in AGENTS.md when it exists. Review current diff and relevant components. Do not edit files. Report actionable accessibility and interaction findings."
    },
    "ui-redesign": {
      "description": "Run the full UI/web redesign workflow in one request.",
      "agent": "ui-web-orchestrator",
      "subtask": true,
      "template": "Run the full UI/web redesign workflow for: $ARGUMENTS\n\nRead the detailed UI policy file defined in AGENTS.md when it exists. Classify intent first. If this is options/audit/plan-only, do not implement; return options/plan and stop. If implementation is requested, orchestrate audit, planning, implementation, accessibility review, and verification automatically unless a gated action is hit. Return one consolidated final report."
    },
    "ui-mcp-setup": {
      "description": "Configure the UI MCP stack for OpenCode.",
      "agent": "devops",
      "subtask": false,
      "template": "Configure the UI MCP stack for OpenCode: $ARGUMENTS\n\nUse docs/UI_MCP_INSTALL_FOR_AGENT.md as the source of truth. Backup config before editing. Official shadcn MCP is primary with the standard shadcn registry. Official shadcn MCP may use GitHub/public shadcn-compatible registries when named by the user/project or visible MCP tools/config can inspect them. Jpisnice shadcn-ui-mcp-server is secondary/reference MCP and must use a GitHub token via local secret. UUPM is design intelligence only. Local/private/authenticated registry setup is a gated action."
    },
    "uupm-setup": {
      "description": "Install or configure UI UX Pro Max / UUPM design-intelligence support for OpenCode.",
      "agent": "devops",
      "subtask": false,
      "template": "Install or configure UI UX Pro Max / UUPM for OpenCode: $ARGUMENTS\n\nUse docs/UUPM_INSTALL_FOR_AGENT.md as the source of truth. Do not overwrite existing config without backups. UUPM is design intelligence only, not a component MCP server."
    },
    "review": {
      "description": "Review code/diff/PR/commit/branch/workspace; prefer OCR/open-code-review when available and approved.",
      "agent": "reviewer",
      "subtask": true,
      "template": "Review this code/diff/PR/commit/branch/workspace: $ARGUMENTS\n\nStart with the startup checkpoint and gated/privacy check. Prefer OCR/open-code-review when installed and approved; OCR is read-only locally but may send code/diffs/context to the configured OCR LLM provider. If OCR is unavailable or not approved, fall back to native read-only review and say why. Do not edit files or apply fixes unless a separate fix request is normalized and allowed."
    }
  }
}
